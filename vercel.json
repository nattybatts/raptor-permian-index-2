{
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/merch",
      "destination": "/api/merch-page"
    },
    {
      "source": "/merch/images/black-hat.jpg",
      "destination": "/api/merch-image?file=black-hat.jpg"
    },
    {
      "source": "/merch/images/white-hat.jpg",
      "destination": "/api/merch-image?file=white-hat.jpg"
    },
    {
      "source": "/merch/images/black-trucker-gold.jpg",
      "destination": "/api/merch-image?file=black-trucker-gold.jpg"
    },
    {
      "source": "/merch/images/white-trucker-black.jpg",
      "destination": "/api/merch-image?file=white-trucker-black.jpg"
    },
    {
      "source": "/merch/images/diesel-surcharge.jpg",
      "destination": "/api/merch-image?file=diesel-surcharge.jpg"
    },
    {
      "source": "/logo.png",
      "destination": "/api/logo"
    },
    {
      "source": "/",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/cron.js": {
      "maxDuration": 300
    }
  }
}
